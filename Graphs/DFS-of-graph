class Solution:
    def dfs(self, adj):
        # code here
        visited = [False]*len(adj)
        ans = []
        
        def solve(u):
            if visited[u]:
                return
            
            visited[u] = True
            ans.append(u)
            
            for v in adj[u]:
                solve(v)
        
        solve(0)
        return ans
