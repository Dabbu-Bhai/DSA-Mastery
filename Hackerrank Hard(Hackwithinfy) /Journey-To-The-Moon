def journeyToMoon(n, astronaut):
    # Write your code here
    graph = [[] for _ in range(n)]
    visited = [False] * n
    
    for i,j in astronaut:
        graph[i].append(j)
        graph[j].append(i)
        
    total_pairs = (n * (n-1)) // 2
    
    def dfs(u , visited , graph):
        visited[u] = True
        vertices = 1
        for v in graph[u]:
            if visited[v] is False:
                vertices += dfs(v , visited , graph)
        return vertices
        
    for node in range(n):
        if visited[node] is False:
            same_country_people = dfs(node , visited , graph)
            total_pairs -= (same_country_people * (same_country_people-1)) // 2
    return total_pairs
