def separateNumbers(s):
    # Write your code here
    if len(s)==0:
        print("NO") 
        return
        
    for i in range(1 , len(s)//2+1):
        genstr = s[:i]
        prev = int(genstr)
        
        while len(genstr) < len(s):
            next = prev+1
            genstr = genstr + str(next)
            prev = next
            
        if genstr == s:
            print("YES",s[:i])
            return
    
    print("NO")
        
